{
  "name": "codesearch-tree-sitter-service",
  "version": "1.0.0",
  "description": "Tree-sitter parsing service for COA CodeSearch MCP",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build:exe": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile ../tree-sitter-service.exe",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile ../tree-sitter-service-linux",
    "build:macos": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile ../tree-sitter-service-macos",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vscode/tree-sitter-wasm": "^0.0.5-php.2",
    "web-tree-sitter": "^0.25.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}